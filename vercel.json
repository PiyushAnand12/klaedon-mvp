{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "Front-end/**", "use": "@vercel/static-build", "config": { "distDir": "Front-end" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/Front-end/$1" }
  ]
}
